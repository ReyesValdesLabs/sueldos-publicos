---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { sitePath } from "@/lib/site-path";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, image = "sueldospublicos-mark.png", imageAlt = "Marca de Sueldos Públicos", type = "website", noindex = false, structuredData } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const imageUrl = new URL(sitePath(image), Astro.site ?? Astro.url);
const robotsContent = noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large";
const jsonLd = structuredData ? JSON.stringify(structuredData).replace(/</g, "\\u003c") : undefined;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0d47a1" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="Sueldos Públicos" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={imageUrl.href} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl.href} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="icon" type="image/svg+xml" href={sitePath("favicon.svg")} />
    <link rel="icon" type="image/png" href={sitePath("sueldospublicos-mark.png")} />
    <title>{title}</title>
    {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("sp-theme");
        const theme = saved === "light" || saved === "dark"
          ? saved
          : matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.classList.toggle("dark", theme === "dark");
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5034305532752206"
     crossorigin="anonymous">
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <Header />
    <main id="main-content"><slot /></main>
    <Footer />
    <script>
      const themeButton = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
      const applyTheme = (theme: string) => {
        const dark = theme === "dark";
        document.documentElement.classList.toggle("dark", dark);
        document.documentElement.dataset.theme = theme;
        localStorage.setItem("sp-theme", theme);
        if (themeButton) themeButton.setAttribute("aria-label", dark ? "Cambiar a tema claro" : "Cambiar a tema oscuro");
      };
      themeButton?.addEventListener("click", () => {
        const current = document.documentElement.dataset.theme || "light";
        applyTheme(current === "dark" ? "light" : "dark");
      });
      applyTheme(document.documentElement.dataset.theme || "light");
    </script>
  </body>
</html>
