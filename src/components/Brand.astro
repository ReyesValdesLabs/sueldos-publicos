---
import { sitePath } from "@/lib/site-path";

interface Props {
  compact?: boolean;
  class?: string;
}

const { compact = false, class: className } = Astro.props;
---

<span class:list={["brand-lockup", { "brand-lockup--compact": compact }, className]}>
  <span class="brand-symbol" aria-hidden="true">
    <img src={sitePath("sueldospublicos-mark.png")} alt="" width="512" height="512" />
  </span>
  <span class="brand-wordmark" aria-hidden="true">
    <span>sueldos</span><strong>publicos</strong><small>.cl</small>
  </span>
</span>
