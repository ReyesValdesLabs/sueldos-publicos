---
import Brand from "@/components/Brand.astro";
import { sitePath } from "@/lib/site-path";
---
<footer class="site-footer print:hidden">
  <div class="page-shell footer-grid">
    <div><a href={sitePath()} class="brand" aria-label="Sueldos Públicos, inicio"><Brand /></a><p>Herramientas gratuitas para entender remuneraciones del sector público chileno.</p></div>
    <div><strong>Herramientas</strong><a href={sitePath("#calculadora")}>Liquidación docente</a><a href={sitePath("legal/")}>Respaldo legal</a></div>
    <div><strong>Información</strong><a href={sitePath("privacidad/")}>Privacidad</a><a href={sitePath("terminos/")}>Términos de uso</a></div>
  </div>
  <div class="page-shell footer-bottom"><span>© {new Date().getFullYear()} Sueldos Públicos</span><span>Sitio informativo independiente · No es un portal gubernamental</span></div>
</footer>
